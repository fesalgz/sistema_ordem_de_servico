<%- include('../partials/header') %>

    <div class="card">
        <div class="card-header">
            <h2>
                <%= cliente ? 'Editar Cliente' : 'Cadastrar Novo Cliente' %>
            </h2>
            <a href="/clientes" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Voltar</a>
        </div>

        <form action="<%= cliente ? '/clientes/atualizar/' + cliente.id : '/clientes/salvar' %>" method="POST"
            class="form-grid">
            <div class="form-group col-12">
                <label for="nome">Nome Completo *</label>
                <input type="text" id="nome" name="nome" class="form-control" value="<%= cliente ? cliente.nome : '' %>"
                    required>
            </div>

            <div class="form-group col-6">
                <label for="telefone">Telefone *</label>
                <input type="text" id="telefone" name="telefone" class="form-control"
                    value="<%= cliente ? cliente.telefone : '' %>" required minlength="14" maxlength="15">
            </div>

            <div class="form-group col-6">
                <label for="cpf">CPF *</label>
                <input type="text" id="cpf" name="cpf" class="form-control" value="<%= cliente ? cliente.cpf : '' %>"
                    required minlength="14" maxlength="14">
            </div>

            <div class="form-group col-12">
                <label for="observacoes">Observações</label>
                <textarea id="observacoes" name="observacoes" class="form-control"
                    rows="4"><%= cliente ? cliente.observacoes : '' %></textarea>
            </div>

            <div class="form-group col-12 form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Salvar Cliente</button>
                <a href="/clientes" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const cpfInput = document.getElementById('cpf');
            const telInput = document.getElementById('telefone');

            if (cpfInput) {
                cpfInput.addEventListener('input', function (e) {
                    let val = e.target.value.replace(/\D/g, '');
                    if (val.length > 11) val = val.slice(0, 11);
                    val = val.replace(/(\d{3})(\d)/, '$1.$2');
                    val = val.replace(/(\d{3})(\d)/, '$1.$2');
                    val = val.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
                    e.target.value = val;
                });
            }

            if (telInput) {
                telInput.addEventListener('input', function (e) {
                    let val = e.target.value.replace(/\D/g, '');
                    if (val.length > 11) val = val.slice(0, 11);
                    if (val.length > 10) {
                        val = val.replace(/^(\d{2})(\d{5})(\d{4}).*/, '($1) $2-$3');
                    } else if (val.length > 6) {
                        val = val.replace(/^(\d{2})(\d{4})(\d{0,4}).*/, '($1) $2-$3');
                    } else if (val.length > 2) {
                        val = val.replace(/^(\d{2})(\d+)/, '($1) $2');
                    } else if (val.length > 0) {
                        val = val.replace(/^(\d+)/, '($1');
                    }
                    e.target.value = val;
                });
            }
        });
    </script>

    <%- include('../partials/footer') %>