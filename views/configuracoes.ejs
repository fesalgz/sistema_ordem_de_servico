<%- include('partials/header') %>

    <div class="container" style="margin-top: 20px;">
        <h2><i class="fas fa-cog"></i> Configurações do Sistema</h2>
        <p class="text-muted">Ajuste os dados que aparecem no cabeçalho das ordens de serviço impressas.</p>

        <div class="card" style="max-width: 600px; margin-top: 20px;">
            <div class="card-body">
                <form action="/configuracoes/salvar" method="POST" enctype="multipart/form-data">

                    <div class="form-group mb-3">
                        <label>Nome da Empresa</label>
                        <input type="text" name="empresa_nome" class="form-control"
                            value="<%= config.empresa_nome || '' %>" required>
                    </div>

                    <div class="form-group mb-3">
                        <label>Endereço Completo</label>
                        <input type="text" name="empresa_endereco" class="form-control"
                            value="<%= config.empresa_endereco || '' %>"
                            placeholder="Ex: Rua Exemplo, 123 - Centro - Cidade/UF" required>
                    </div>

                    <div class="form-group mb-3">
                        <label>Telefone de Contato</label>
                        <input type="text" name="empresa_telefone" class="form-control"
                            value="<%= config.empresa_telefone || '' %>" required>
                    </div>
            </div>

            <hr>

            <div class="form-group mb-4 mt-3 p-3 bg-light rounded border">
                <div class="form-check form-switch d-flex align-items-center">
                    <input class="form-check-input" type="checkbox" id="tema_escuro" name="tema_escuro"
                        style="width: 40px; height: 20px; cursor: pointer;" <%=config.tema_escuro===1 ? 'checked' : ''
                        %>>
                    <label class="form-check-label ms-3" for="tema_escuro" style="cursor: pointer;">
                        <strong><i class="fas fa-moon"></i> Ativar Modo Escuro (Dark Mode)</strong>
                    </label>
                </div>
                <small class="text-muted d-block mt-2">Ative essa opção para aplicar um tema escuro em todo o
                    sistema, ideal para descansar a visão.</small>
            </div>

            <hr>

            <div class="form-group mb-3">
                <label>Logo da Empresa</label><br>
                <% if (config.logo_path) { %>
                    <div style="margin-bottom: 15px;">
                        <img src="<%= config.logo_path %>" alt="Logo Atual"
                            style="max-height: 80px; border: 1px solid #ddd; padding: 5px; border-radius: 4px;">
                        <br><small class="text-muted">Logo Atual</small>
                    </div>
                    <% } %>
                        <input type="file" name="logo" class="form-control-file" accept="image/*">
                        <small class="form-text text-muted">Selecione uma imagem (.png, .jpg) para atualizar a
                            logo. Deixe em branco para manter a atual.</small>
            </div>

            <hr>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Salvar
                    Configurações</button>
            </div>
            </form>
        </div>
    </div>
    <div class="card" style="max-width: 600px; margin-top: 30px;">
        <div class="card-header bg-danger text-white">
            <i class="fas fa-database"></i> Gerenciamento do Banco de Dados
        </div>
        <div class="card-body">
            <p><strong>Tamanho Atual do Banco:</strong> <span class="badge bg-secondary">
                    <%= typeof dbSize !=='undefined' ? dbSize : 'Desconhecido' %>
                </span></p>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <!-- Backup -->
                <a href="/configuracoes/backup" class="btn btn-success">
                    <i class="fas fa-download"></i> Fazer Backup do Banco (.db)
                </a>

                <!-- Apagar OS -->
                <form action="/configuracoes/limpar-os" method="POST"
                    onsubmit="return confirm('TEM CERTEZA ABSOLUTA?\n\nIsso irá apagar TODAS as Ordens de Serviço cadastradas permanentemente e não poderá ser desfeito!');"
                    style="display:inline;">
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-trash-alt"></i> Apagar Todas as OS
                    </button>
                </form>

                <!-- Apagar Clientes -->
                <form action="/configuracoes/limpar-clientes" method="POST"
                    onsubmit="return confirm('ATENÇÃO: TEM CERTEZA?\n\nIsso irá apagar a lista de TODOS os Clientes cadastrados permanentemente!');"
                    style="display:inline;">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-users-slash"></i> Apagar Todos os Clientes
                    </button>
                </form>
            </div>

            <hr class="mt-4 mb-3">

            <h6 class="mb-2"><strong>Restaurar Backup Anterior</strong></h6>
            <form action="/configuracoes/restaurar" method="POST" enctype="multipart/form-data"
                class="d-flex flex-wrap align-items-center gap-2"
                onsubmit="return confirm('ATENÇÃO EXTREMA: \n\nA restauração apaga absolutamente todos os dados atuais do seu sistema de hoje e os substitui pelo arquivo enviado. Só confirme se tiver certeza absoluta do histórico!');">
                <input type="file" name="banco" class="form-control form-control-sm" accept=".db,.sqlite" required
                    style="max-width: 300px;">
                <button type="submit" class="btn btn-primary btn-sm" style="height: 31px;">
                    <i class="fas fa-upload"></i> Subir Backup
                </button>
            </form>

            <small class="text-muted d-block mt-4">
                <i class="fas fa-info-circle"></i> O botão de "Apagar" realiza a limpeza das tabelas e imediatamente
                otimiza o peso do arquivo devolvendo espaço ao computador. Faça backup sempre antes de clicar.
            </small>
        </div>
    </div>

    </div>

    <%- include('partials/footer') %>