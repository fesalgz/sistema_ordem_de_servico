<%- include('../partials/header') %>

    <div class="container" style="margin-top: 20px;">
        <h2><i class="fas fa-user-edit"></i> Editar Funcionário</h2>
        <p class="text-muted">Atualize os dados de acesso e identificação deste funcionário.</p>

        <div class="card" style="max-width: 600px; margin-top: 20px;">
            <div class="card-body">
                <form action="/funcionarios/editar/<%= func.id %>" method="POST">

                    <div class="form-group mb-3">
                        <label>Nome Completo</label>
                        <input type="text" name="nome" class="form-control" value="<%= func.nome %>" required>
                    </div>

                    <div class="form-group mb-3">
                        <label>Nome Curto (Aparecerá na OS)</label>
                        <input type="text" name="nome_os" class="form-control" value="<%= func.nome_os %>" required>
                    </div>

                    <div class="form-group mb-3">
                        <label>Usuário de Login</label>
                        <input type="text" name="username" class="form-control" value="<%= func.username %>" required>
                    </div>

                    <div class="form-group mb-3">
                        <label>Nova Senha</label>
                        <input type="password" name="password" class="form-control"
                            placeholder="Deixe em branco para manter a senha atual">
                    </div>

                    <div class="form-group mb-3">
                        <label>Cargo</label>
                        <select name="role" class="form-control">
                            <option value="atendente" <%=func.role==='atendente' ? 'selected' : '' %>>Atendente</option>
                            <option value="gerente" <%=func.role==='gerente' ? 'selected' : '' %>>Gerente</option>
                            <% if (user.role==='admin' ) { %>
                                <option value="admin" <%=func.role==='admin' ? 'selected' : '' %>>Administrador</option>
                                <% } %>
                        </select>
                    </div>

                    <div class="form-group mt-4 flex-between">
                        <a href="/funcionarios" class="btn btn-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Salvar
                            Alterações</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>