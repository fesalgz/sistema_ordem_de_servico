<%- include('../partials/header') %>

    <div class="container" style="margin-top: 20px;">
        <h2>Gerenciar Funcionários</h2>

        <div class="card" style="margin-bottom: 20px;">
            <div class="card-body">
                <h4>Novo Funcionário</h4>
                <form action="/funcionarios/add" method="POST">
                    <div class="form-group">
                        <label>Nome Completo</label>
                        <input type="text" name="nome" class="form-control" required>
                    </div>
                    <div class="form-group row" style="display:flex; gap:10px; margin-top:10px;">
                        <div style="flex:1">
                            <label>Nome na Ordem (Curto)</label>
                            <input type="text" name="nome_os" class="form-control" required>
                        </div>
                        <div style="flex:1">
                            <label>Usuário de Login</label>
                            <input type="text" name="username" class="form-control" required>
                        </div>
                        <div style="flex:1">
                            <label>Senha</label>
                            <input type="password" name="password" class="form-control" required>
                        </div>
                        <div style="flex:1">
                            <label>Cargo</label>
                            <select name="role" class="form-control">
                                <option value="atendente">Atendente</option>
                                <option value="gerente">Gerente</option>
                                <% if (user.role==='admin' ) { %>
                                    <option value="admin">Administrador</option>
                                    <% } %>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary" style="margin-top: 15px;">Cadastrar</button>
                </form>
            </div>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Nome na OS</th>
                    <th>Usuário</th>
                    <th>Cargo</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% funcionarios.forEach(func=> { %>
                    <tr>
                        <td>
                            <%= func.id %>
                        </td>
                        <td>
                            <%= func.nome %>
                        </td>
                        <td>
                            <%= func.nome_os || '-' %>
                        </td>
                        <td>
                            <%= func.username %>
                        </td>
                        <td>
                            <% if (func.role==='admin' ) { %>
                                <span class="badge"
                                    style="background:#007bff; color:#fff; padding:3px 8px; border-radius:4px;">Administrador</span>
                                <% } else if (func.role==='gerente' ) { %>
                                    <span class="badge"
                                        style="background:#6f42c1; color:#fff; padding:3px 8px; border-radius:4px;">Gerente</span>
                                    <% } else { %>
                                        <span class="badge"
                                            style="background:#17a2b8; color:#fff; padding:3px 8px; border-radius:4px;">Atendente</span>
                                        <% } %>
                        </td>
                        <td>
                            <% if (user.role==='admin' || user.role==='gerente' ) { %>
                                <a href="/funcionarios/editar/<%= func.id %>" class="btn btn-sm btn-info"
                                    title="Editar"><i class="fas fa-edit"></i> Editar</a>
                                <% } %>
                                    <% if (user.role==='admin' || (user.role==='gerente' && func.role !=='gerente' )) {
                                        %>
                                        <form action="/funcionarios/delete/<%= func.id %>" method="POST"
                                            style="display:inline;"
                                            onsubmit="return confirm('Tem certeza que deseja excluir este funcionário?');">
                                            <button type="submit" class="btn btn-sm btn-danger"><i
                                                    class="fas fa-trash"></i> Excluir</button>
                                        </form>
                                        <% } %>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>
    </div>

    <%- include('../partials/footer') %>